# Copier ce fichier en ".env" (jamais commité, voir .gitignore) et renseigner les valeurs.

# Port d'écoute du serveur Express
PORT=3000

# Secret de session Express (cookies httpOnly). À changer en prod, garder aléatoire et long.
SESSION_SECRET=change-me-in-production

# Secret partagé avec le "manager" (bot Discord) pour authentifier sa connexion Socket.io.
# Sans ce secret, n'importe qui pourrait se faire passer pour le manager.
MANAGER_SECRET=

# Webhook Discord (optionnel) pour les notifications de crash / backup échoué.
DISCORD_WEBHOOK_URL=

# Compte admin créé automatiquement au premier démarrage si absent de la base.
# Laisser vide pour ne pas créer de compte automatiquement (ex: en prod si déjà seedé).
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# Compte premium de test créé automatiquement au premier démarrage si absent de la base.
# Utile pour valider le système de rôles (Phase 2) tant qu'il n'y a pas d'écran de gestion
# des comptes premium (Phase 5). Laisser vide si non nécessaire.
PREMIUM_SEED_EMAIL=
PREMIUM_SEED_PASSWORD=

# Discord OAuth2 (panel premium public, Phase 5) — même appli Discord que le bot.
# Client ID/Secret : Discord Developer Portal > ton appli > onglet "OAuth2".
# Redirect URI à enregistrer côté Discord : doit correspondre EXACTEMENT à DISCORD_REDIRECT_URI.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
# URL du frontend vers laquelle rediriger une fois le login Discord terminé.
PREMIUM_WEB_REDIRECT=http://localhost:5173/premium

# Phase 6 — restriction VPN du panel admin (Option C, cf. deploy/cloudflared/README.md).
# Laisser vide en dev local : aucune restriction n'est appliquée sans cette valeur.
# En prod, doit correspondre exactement au hostname du tunnel Cloudflare admin
# (protégé par Cloudflare Access) — ex: admin.dashboard.killianrms.com
ADMIN_HOSTNAME=
